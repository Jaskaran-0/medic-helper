<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- First Name Label -->
        <TextView
            android:id="@+id/tv_first_name_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/first_name_label"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="12dp"/>

        <!-- First Name Input -->
        <EditText
            android:id="@+id/et_first_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/first_name_hint"
            android:textColor="@android:color/black"
            android:background="@android:color/white"
            android:textSize="16sp"
            android:padding="10dp"/>

        <!-- Last Name Label -->
        <TextView
            android:id="@+id/tv_last_name_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/last_name_label"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="12dp"/>

        <!-- Last Name Input -->
        <EditText
            android:id="@+id/et_last_name"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/last_name_hint"
            android:textColor="@android:color/black"
            android:background="@android:color/white"
            android:textSize="16sp"
            android:padding="10dp"/>

        <!-- Email Label -->
        <TextView
            android:id="@+id/tv_email_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/email_label"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="12dp"/>

        <!-- Email Input -->
        <EditText
            android:id="@+id/et_email"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/email_hint"
            android:inputType="textEmailAddress"
            android:textColor="@android:color/black"
            android:background="@android:color/white"
            android:textSize="16sp"
            android:padding="10dp"/>

        <!-- Phone Number Label -->
        <TextView
            android:id="@+id/tv_phone_number_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/phone_number_label"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="12dp"/>

        <!-- Phone Number Input -->
        <EditText
            android:id="@+id/et_phone_number"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="@string/phonenumber_hint"
            android:inputType="phone"
            android:textColor="@android:color/black"
            android:background="@android:color/white"
            android:textSize="16sp"
            android:padding="10dp"/>

        <!-- Date of Birth Label -->
        <TextView
            android:id="@+id/tv_dob_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/dob_label"
            android:textSize="20sp"
            android:textColor="@android:color/black"
            android:layout_marginTop="12dp"/>

        <!-- Date of Birth Input (Disabled) -->
        <EditText
            android:id="@+id/et_dob"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:enabled="false"
            android:textColor="@android:color/darker_gray"
            android:background="@android:color/white"
            android:textSize="16sp"
            android:padding="10dp"/>

        <!-- Save Button -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/save"
            android:background="@android:color/white"
            android:textColor="@android:color/black"
            android:textSize="18sp"
            android:padding="12dp"/>
    </LinearLayout>
</ScrollView>
